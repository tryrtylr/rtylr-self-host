# Global version pin. A single RTYLR_VERSION pins ALL rtylr images (backend and
# frontends) to the same Docker tag, Retool-style. Bump this one value to upgrade
# the whole stack, then run ./scripts/update.sh (Compose) or `helm upgrade` (Helm).
RTYLR_VERSION=1.0.0

# Image source. Images are published to Docker Hub under the `rtylr` namespace.
RTYLR_IMAGE_REGISTRY=docker.io
RTYLR_IMAGE_NAMESPACE=rtylr
